# Supabase — Beena's Bake House order form backend
# Create a free project at https://supabase.com and copy these from:
# Project Settings → Data API → URL & anon public key
#
# Then run this SQL in the Supabase SQL editor to create the orders table:
#
#   create table public.orders (
#     id uuid primary key default gen_random_uuid(),
#     name text not null,
#     phone text not null,
#     cake_type text not null,
#     message text,
#     preferred_date date,
#     created_at timestamptz not null default now()
#   );
#   alter table public.orders enable row level security;
#   create policy "anon can insert orders" on public.orders
#     for insert to anon with check (true);
#
# NOTE: enabling RLS with an INSERT-only anon policy is the minimum-permission
# pattern for a public order form. No SELECT/UPDATE/DELETE is allowed to anon.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key